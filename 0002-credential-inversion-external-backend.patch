+++ b/roles/storage_external/tasks/main.yml
@@ -0,0 +1,76 @@
+---
+# No provisioning. This role's job is to prove the store is usable and then
+# publish the contract — the same contract aistor/seaweedfs publish, so cnpg
+# and byoc_logs cannot tell the difference.
+- name: Assert the external S3 store is fully specified
+  ansible.builtin.assert:
+    that:
+      - external_s3_host is defined and external_s3_host != "CHANGE_ME"
+      - external_s3_port is defined
+      - external_s3_scheme in ["http", "https"]
+      - external_s3_access_key is defined and external_s3_access_key != "CHANGE_ME"
+      - external_s3_secret_key is defined and external_s3_secret_key != "CHANGE_ME"
+    fail_msg: >-
+      s3_backend=external needs external_s3_host / _port / _scheme in
+      group_vars/all/main.yml and external_s3_access_key / _secret_key in the
+      vaulted secrets.yml.
+    quiet: true
+
+- name: Create the namespace for mc pods and the credentials Secret
+  kubernetes.core.k8s:
