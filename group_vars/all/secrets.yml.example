---
# ---------------------------------------------------------------------------
# TEMPLATE — copy, fill in, encrypt. This file is committed; the real one is not.
#
#   cp group_vars/all/secrets.yml.example group_vars/all/secrets.yml
#   $EDITOR group_vars/all/secrets.yml           # fill in every CHANGE_ME
#   ansible-vault encrypt group_vars/all/secrets.yml
#
# Ansible only auto-loads .yml/.yaml/.json from group_vars, so the .example
# extension means this file is never read at runtime.
#
# site.yml refuses to run while any CHANGE_ME remains (per active backend).
# ---------------------------------------------------------------------------

# --- Always required ---

# Datadog API key. Datadog > Organization Settings > API Keys.
# Used by: the self-monitoring agent, and BYOC Logs itself.
datadog_api_key: "CHANGE_ME"

# --- Required when s3_backend is aistor or seaweedfs ---

# The app credentials you WANT these backends to create. They are an INPUT to a
# managed backend, which then scopes them to s3_buckets. Not looked up anywhere
# — invent them:
#   access key: 20 chars, A-Z0-9      secret key: 40 chars
# (For s3_backend: external the credentials are an OUTPUT of someone else's
# system — see external_s3_* below — and these are unused.)
s3_app_access_key: "CHANGE_ME"
s3_app_secret_key: "CHANGE_ME"

# --- Required when s3_backend: aistor ---

# AIStor eval license — free single-node licence from SUBNET (min.io).
aistor_license: "CHANGE_ME"

# Root password of the AIStor tenant. Used only to provision buckets and the
# scoped app key above. NOTE: newer AIStor charts REJECT the weak minio/minio123
# pair, so set a strong value here (12+ chars). The root USER is byocadmin (a
# role default, deliberately not "minio").
aistor_root_password: "CHANGE_ME"

# --- Required when s3_backend: seaweedfs ---

# Secret half of the SeaweedFS admin identity (access key half is a role
# default). Used only to create buckets.
seaweedfs_admin_secret_key: "CHANGE_ME"

# --- Required when s3_backend: external ---

# Credentials issued BY the store you're pointing at. The playbook does not
# create these; it validates them and publishes them to the rest of the stack.
external_s3_access_key: "CHANGE_ME"
external_s3_secret_key: "CHANGE_ME"
