---
extends: default
rules:
  line-length:
    max: 120
    level: warning
  comments:
    min-spaces-from-content: 1
  comments-indentation: false      # required by ansible-lint
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
ignore: |
  .kubeconfig/
