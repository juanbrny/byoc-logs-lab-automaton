---
# TEMPLATE — copy to inventory/hosts.yml:
#   cp inventory/hosts.yml.example inventory/hosts.yml
#
# SSH variant: the workstation reaches the node over SSH *and* reaches the
# cluster API over the network. For AWS/SSM (no SSH, no inbound), start from
# inventory/hosts-ssm.yml.example instead.
#
# Two groups, and both matter:
#   lab_node    — the machine k3s is installed on.
#   k8s_control — where kubectl/helm/kubernetes.core RUN. Here: the
#                 workstation, which needs network access to the API server.
all:
  children:
    lab_node:
      hosts:
        # Use the node's REAL hostname as the inventory name. A mismatch here
        # is how you end up debugging the wrong cluster.
        byoc-lab-node:
          ansible_host: 10.0.0.10
          ansible_user: root

    k8s_control:
      hosts:
        localhost:
          ansible_connection: local
